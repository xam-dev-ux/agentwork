# Clave privada del agente (configurar en Render como variable de entorno, NUNCA en código)
AGENT_PRIVATE_KEY=0x...

# Dirección del contrato AgentWork desplegado
AGENT_WORK_ADDRESS=0xb0548a2e387ff0162ada0903251385015c6cae45

# USDC en Arc Testnet
USDC_ADDRESS=0x3600000000000000000000000000000000000000

# Google AI Studio API Key (gratuita en aistudio.google.com/app/apikey)
